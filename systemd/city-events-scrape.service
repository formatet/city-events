[Unit]
Description=City Events Scraper
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/city-events
Environment="PATH=/opt/city-events/venv/bin"
ExecStart=/opt/city-events/venv/bin/python3 /opt/city-events/scrape_all.py
StandardOutput=append:/opt/city-events/logs/scrape_stdout.log
StandardError=append:/opt/city-events/logs/scrape_stdout.log

[Install]
WantedBy=multi-user.target
